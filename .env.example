# Jupitar Environment Variables

# Database
MONGODB_URI=mongodb://mongodb:27017/jupitar

# Backend
PORT=8052
DATABASE_URL=mongodb://mongodb:27017/jupitar

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8052
# In Cloud Shell, replace with:
# NEXT_PUBLIC_API_URL=https://<port>-<shell-url>.cloudshell.dev

# Reown (WalletConnect) – get your projectId at https://cloud.reown.com
VITE_REOWN_PROJECT_ID=your_project_id_here
